# ==========================================
# Z-UI Configuration
# https://github.com/Zendan-ui/z-ui
# Telegram: @Zendan_Ui
# ==========================================

# Server
ZUI_HOST=0.0.0.0
ZUI_PORT=8443
ZUI_BASE_PATH=/
ZUI_TLS_CERT=
ZUI_TLS_KEY=
ZUI_DEBUG=false

# Database (postgres or sqlite)
ZUI_DB_TYPE=sqlite
ZUI_DB_HOST=localhost
ZUI_DB_PORT=5432
ZUI_DB_NAME=zui
ZUI_DB_USER=zui
ZUI_DB_PASS=changeme
ZUI_DB_SSL=disable
ZUI_DB_SQLITE=./data/zui.db

# Redis (optional)
ZUI_REDIS_URL=redis://localhost:6379
ZUI_REDIS_PASS=
ZUI_REDIS_DB=0

# Authentication
ZUI_JWT_SECRET=change-me-in-production
ZUI_JWT_EXPIRY=24
ZUI_REFRESH_EXPIRY=168
ZUI_ADMIN_USER=admin
ZUI_ADMIN_PASS=admin
ZUI_ENABLE_2FA=false
ZUI_MAX_LOGIN_ATTEMPTS=5
ZUI_LOCKOUT_DURATION=15

# Xray Core
ZUI_XRAY_PATH=/usr/local/bin/xray
ZUI_XRAY_CONFIG=./data/xray/config.json
ZUI_XRAY_ASSETS=/usr/local/share/xray
ZUI_XRAY_LOG=./data/logs/xray.log
ZUI_XRAY_API_PORT=10085
ZUI_XRAY_STATS=true

# Sing-box
ZUI_SINGBOX_PATH=/usr/local/bin/sing-box
ZUI_SINGBOX_CONFIG=./data/singbox/config.json
ZUI_SINGBOX_LOG=./data/logs/singbox.log

# Telegram Bot
ZUI_TELEGRAM_ENABLED=false
ZUI_TELEGRAM_TOKEN=
ZUI_TELEGRAM_ADMIN_ID=0

# Cluster
ZUI_CLUSTER_ENABLED=false
ZUI_NODE_ID=master
ZUI_MASTER_URL=
ZUI_SYNC_INTERVAL=30

# Monitoring
ZUI_MONITORING_ENABLED=true
ZUI_PROMETHEUS_PORT=9090
ZUI_RETENTION_DAYS=30

# GeoIP
ZUI_GEOIP_PATH=./data/geo/geoip.dat
ZUI_GEOSITE_PATH=./data/geo/geosite.dat
ZUI_GEO_AUTO_UPDATE=true

# Theme (dark, darker, amoled)
ZUI_DEFAULT_THEME=amoled
